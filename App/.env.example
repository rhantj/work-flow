# ===== 공통 (docker-compose / backend_spring / backend_fastAPI 에서 사용) =====
# 아래 값들은 로컬 개발용 예시다. 서버(OCI 등)에 배포할 때는 반드시 실제 값으로 바꿀 것 —
# 특히 POSTGRES_PASSWORD, JWT_SECRET을 예시 그대로 쓰면 안 된다.
POSTGRES_DB=workflow
POSTGRES_USER=postgres
POSTGRES_PASSWORD=root
DATABASE_URL=postgresql://postgres:root@localhost:5432/workflow
# 로컬에 5432를 이미 쓰는 PostgreSQL이 있다면 아래 두 줄의 주석을 풀고 포트를 바꿔서 쓸 것
# (DATABASE_URL의 포트도 같이 맞춰줘야 함)
# DB_HOST_PORT=5433

REDIS_URL=redis://localhost:6379/0

KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ===== backend_spring (Spring Boot) =====
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-bytes

# backend_spring JDBC 연결
# docker-compose 기본값은 compose 안의 db 서비스다.
# Spring을 로컬 머신에서 직접 실행할 때만 jdbc:postgresql://localhost:5432/workflow 로 바꾼다.
# Supabase 원격 연결은 프로젝트 대시보드 > Database > Connection string(URI, Session pooler 권장)을
# jdbc:postgresql:// 형식으로 바꾸고 끝에 ?sslmode=require 를 붙인다.
# Railway 등 배포 환경에서 DATABASE_URL 또는 PGHOST/PGUSER/PGPASSWORD가 제공되면
# backend_spring이 SPRING_DATASOURCE_*로 자동 변환해서 사용한다.
SPRING_DATASOURCE_URL=jdbc:postgresql://db:5432/workflow
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=root

# Supabase 프로젝트 URL/키 (현재 코드는 JDBC로만 접속하므로 필수는 아니지만,
# 추후 Supabase Storage/Auth를 프론트나 백엔드에서 직접 쓸 경우를 대비해 문서화)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Cloud Console > APIs & Services > Credentials 에서 OAuth 2.0 클라이언트 ID(웹 애플리케이션) 발급.
# 승인된 리디렉션 URI에 아래 GOOGLE_REDIRECT_URI 값을 그대로 등록할 것.
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/api/v1/auth/google/callback
# OAuth 콜백 처리 후 브라우저를 리다이렉트시킬 프론트엔드 주소
WORKFLOW_FRONTEND_BASE_URL=http://localhost:5173

# ===== backend_fastAPI (FastAPI) =====
LLM_API_KEY=sk-your-llm-api-key

# FS-3 ml_delay_risk: 학습된 모델(.pkl)은 git에 커밋하지 않고
# Hugging Face Hub에서 컨테이너 기동 시 내려받는다 (docker-entrypoint.sh 참고).
# 비워두면 다운로드를 건너뛰고, 컨테이너 안에서 직접 학습해야 한다.
DELAY_RISK_HF_MODEL_REPO_ID=your-username/ml_delay_risk_model
# private 저장소일 때만 필요 (Hugging Face Settings > Access Tokens, Read 권한이면 충분)
HF_TOKEN=hf_your-read-token
