DATABASE_URL=postgresql://postgres:root@localhost:5432/workflow
OLLAMA_HOST=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
GENERATION_MODEL=gemma2

# FS-3 ml_delay_risk: 학습된 모델(.pkl)을 Hugging Face Hub에서 내려받으려면 설정
# (python -m ml_delay_risk.fetch_model). 비워두면 다운로드를 건너뛴다.
# 이 파일은 joblib.load()(=pickle)로 역직렬화되므로, 반드시 팀이 통제하는 저장소(가급적
# private)로 지정할 것 — pickle 역직렬화는 파일 내용에 따라 임의 코드를 실행할 수 있어,
# 신뢰할 수 없는 저장소를 지정하면 서버 프로세스 권한으로 코드 실행이 가능해진다.
DELAY_RISK_HF_MODEL_REPO_ID=your-username/ml_delay_risk_model
# 재현성을 위해 커밋 해시나 태그로 고정 권장 (비워두면 기본 브랜치 최신 커밋을 받음)
DELAY_RISK_HF_MODEL_REVISION=
# 다운로드한 파일의 SHA-256. 설정하면 fetch_model.py가 저장 직후 체크섬을 대조해서
# 안 맞는 파일은 신뢰하지 않고(=삭제) 거부한다(저장소 변조 대비). 운영 환경에서는 설정 권장.
# 값을 구하려면: python -c "import hashlib;print(hashlib.sha256(open('delay_model.pkl','rb').read()).hexdigest())"
DELAY_RISK_HF_MODEL_SHA256=
# private 저장소일 때만 필요 (Hugging Face Settings > Access Tokens, Read 권한이면 충분)
HF_TOKEN=hf_your-read-token
# RAG 챗봇(llm_rag_assistant) 답변 생성 모델. 회의록 분석과 같은 HF_MEETING_ANALYSIS_MODEL을
# 재사용한다 (core/config.py Settings.hf_rag_generation_model 참고). 별도 설정 불필요.
# RAG 챗봇 임베딩 모델. 코드 기본값(BAAI/bge-m3)만으로 충분하므로 보통 설정할 필요 없음.
# 다른 모델을 쓰려면 아래 주석을 풀 것.
# HF_EMBEDDING_MODEL=BAAI/bge-m3

# LangSmith 관찰가능성 (RAG 챗봇 LangChain 호출 자동 트레이싱)
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=workflow-ai-rag
# smith.langchain.com에서 발급받아 각자 로컬 .env에만 채울 것 (커밋 금지)
LANGSMITH_API_KEY=
