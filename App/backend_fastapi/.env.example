DATABASE_URL=postgresql://postgres:root@localhost:5432/workflow
OLLAMA_HOST=http://localhost:11434
EMBEDDING_MODEL=nomic-embed-text
GENERATION_MODEL=gemma2

# FS-3 ml_delay_risk: 학습된 모델(.pkl)을 Hugging Face Hub에서 내려받으려면 설정
# (python -m ml_delay_risk.fetch_model). 비워두면 다운로드를 건너뛴다.
DELAY_RISK_HF_MODEL_REPO_ID=your-username/ml_delay_risk_model
# private 저장소일 때만 필요 (Hugging Face Settings > Access Tokens, Read 권한이면 충분)
HF_TOKEN=hf_your-read-token
